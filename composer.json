{
    "name": "softbery/laravel-wweditor",
    "description": "Laravel package for wwEditor - Rich Text Content Editor",
    "type": "laravel-package",
    "keywords": ["laravel", "editor", "wysiwyg", "rich-text", "content"],
    "license": "MIT",
    "authors": [
        {
            "name": "Softbery",
            "email": "info@softbery.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "laravel/framework": "^9.0|^10.0|^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^7.0|^8.0"
    },
    "autoload": {
        "psr-4": {
            "Softbery\\WwEditor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Softbery\\WwEditor\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Softbery\\WwEditor\\WwEditorServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
